;;; sandbox-exec profile for sandbox_run_rust
;;; cargo needs broad read access to toolchain + registry cache.
;;; Network is denied; cargo registry must be pre-populated in the
;;; sandbox dir by the Rust side (offline mode via --offline flag).
(version 1)

(deny default)

(allow process-fork)
(allow process-exec)
(allow signal (target self))

(allow sysctl-read)
(allow mach-lookup)
(allow mach-register)
(allow mach-task-name)
(allow ipc-posix-shm)
(allow system-socket)

;;; ---- file reads: toolchain, system libs ----
(allow file-read*
    (subpath "/usr/bin")
    (subpath "/usr/lib")
    (subpath "/usr/local/lib")
    (subpath "/System/Library")
    (subpath "/bin")
    (subpath "/private/etc")
    (subpath "/private/var/db/timezone")
    (subpath "/usr/share")
    ;; Homebrew LLVM / linker
    (subpath "/opt/homebrew")
    (subpath "/usr/local/Cellar")
    ;; rustup toolchain
    (subpath (param "RUSTUP_HOME"))
    (subpath (param "CARGO_HOME"))
    ;; per-run sandbox
    (subpath (param "SANDBOX_DIR"))
    (subpath "/private/tmp")
    (literal "/dev/null")
    (literal "/dev/random")
    (literal "/dev/urandom")
    (literal "/dev/zero")
)

;;; ---- file writes: only sandbox dir ----
(allow file-write*
    (subpath (param "SANDBOX_DIR"))
)

(allow file-read-metadata
    (literal "/dev")
    (literal "/dev/null")
    (literal "/dev/random")
    (literal "/dev/urandom")
    (literal "/dev/zero")
    (subpath "/private/tmp")
)
(allow file-ioctl
    (literal "/dev/null")
)

(allow file-read-data
    (literal "/dev/stdin")
    (literal "/dev/stdout")
    (literal "/dev/stderr")
)
(allow file-write-data
    (literal "/dev/stdout")
    (literal "/dev/stderr")
)

;;; ---- network: DENY ALL ----
(deny network*)
